          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- verify? No → Return (no verify) -->
        <mxCell id="43" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="15" target="16" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- verify? Yes → Verify with LLM -->
        <mxCell id="44" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="15" target="17" parent="1">
          <mxGeometry relative="1" as="geometry" />
