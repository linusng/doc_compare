        <mxCell id="45" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="17" target="18" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Confirmed? Yes → Return Verified -->
        <mxCell id="46" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="18" target="19" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Confirmed? No → More candidates? -->
        <mxCell id="47" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="18" target="20" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- More candidates? No → Return Last -->
        <mxCell id="48" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="20" target="21" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- More candidates? Yes → loop back left to Gather Full Section -->
        <mxCell id="49" value="Yes (next candidate)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="20" target="13" parent="1">
          <mxGeometry relative="1" as="geometry">
